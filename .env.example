MYSQL_PASSWORD=project_nps
MYSQL_ROOT_PASSWORD=root
DATABASE_URL=mysql://project_nps:project_nps@mysql:3306/project_nps

# Redis
REDIS_HOST_PORT=6379
REDIS_URL=redis://redis:6379

# JWT
JWT_SECRET=your-secret-here
