# Runtime
NODE_ENV=development

# API
API_PORT=3003
API_HOST_PORT=3003

# Web
WEB_HOST_PORT=4200

# MySQL
MYSQL_HOST_PORT=3306
MYSQL_DATABASE=project_nps
